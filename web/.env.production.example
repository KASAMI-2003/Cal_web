# 生产环境构建（npm run build 前复制为 .env.production）
# 使用与站点相同的 HTTPS 域名，由 Nginx 反代到本机 3569 / 8088

VITE_PYTHON_API_ORIGIN=https://calweb.physedu.top
VITE_RUST_API_ORIGIN=https://calweb.physedu.top
# 终端 VASP 入库命令用的 API（SSH 远程机须能访问；与 pyserver 同机时可填 http://127.0.0.1:3569）
VITE_VASP_IMPORT_API_URL=https://calweb.physedu.top
