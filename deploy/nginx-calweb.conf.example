# 复制到服务器：/etc/nginx/conf.d/cal_web.conf
# 修改 server_name、root、证书路径后：sudo nginx -t && sudo systemctl reload nginx
#
# 路由分工：
#   Rust 8088  → /register /login /users/*
#   Python 3569 → /api/* 以及下列不带 /api 前缀的旧接口：
#     /mysql_receive /page2_search /data_input/* /create_lattice_picture /websocket_port /img/*
#   WebSocket 8765 → /api/ssh/ws（须在 /api/ 之前单独配置）
#
# 切勿对 /api/ 做 rewrite 去掉前缀（pyserver 路由本身含 /api）

server {
    listen 80;
    server_name calweb.physedu.top;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name calweb.physedu.top;

    ssl_certificate     /etc/letsencrypt/live/calweb.physedu.top/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/calweb.physedu.top/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /opt/cal_web/Cal_web/web/dist;
    index index.html;

    # ① WebSocket（必须写在 /api/ 之前）
    location /api/ssh/ws {
        proxy_pass http://127.0.0.1:8765;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }

    # ② Rust 用户 API
    location ~ ^/(register|login|users/) {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ③ Python /api/*（原样转发，不要 rewrite）
    location /api/ {
        proxy_pass http://127.0.0.1:3569;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_read_timeout 120s;
    }

    # ④ Python 旧路径（无 /api 前缀）—— 缺此块会导致 POST 405
    location ~ ^/(mysql_receive|page2_search|data_input|create_lattice_picture|websocket_port)(/|$) {
        proxy_pass http://127.0.0.1:3569;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_read_timeout 120s;
    }

    location /img/ {
        proxy_pass http://127.0.0.1:3569;
        proxy_set_header Host $host;
    }

    # ⑤ 前端 SPA（放最后）
    location / {
        try_files $uri /index.html;
    }
}
