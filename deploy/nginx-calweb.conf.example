# 复制到服务器：/etc/nginx/conf.d/cal_web.conf
# 修改 server_name、root、证书路径后：sudo nginx -t && sudo systemctl reload nginx
#
# 重要：
# - 注册/登录走 Rust database（8088），不是 Python
# - Python 的 /api/* 不要 rewrite 去掉前缀（pyserver 路由本身带 /api）
# - 构建前端时设置 VITE_* 为 https://你的域名（见 web/.env.production.example）

server {
    listen 80;
    server_name calweb.physedu.top;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name calweb.physedu.top;

    ssl_certificate     /etc/letsencrypt/live/calweb.physedu.top/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/calweb.physedu.top/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /opt/cal_web/Cal_web/web/dist;
    index index.html;

    location / {
        try_files $uri /index.html;
    }

    # Rust 用户 API（注册 / 登录 / 个人资料）→ database/ 8088
    location ~ ^/(register|login|users/) {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Python API（路径原样转发，不要 rewrite 去掉 /api）
    location /api/ {
        proxy_pass http://127.0.0.1:3569;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Python 其它路由（pyserver 里不带 /api 前缀的接口）
    location ~ ^/(mysql_receive|page2_search|data_input/|create_lattice_picture|websocket_port) {
        proxy_pass http://127.0.0.1:3569;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /img/ {
        proxy_pass http://127.0.0.1:3569;
        proxy_set_header Host $host;
    }

    # 终端 WebSocket（端口与 pyserver 的 TERMINAL_WS_PORT 一致，默认 8765）
    location /api/ssh/ws {
        proxy_pass http://127.0.0.1:8765;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }
}
